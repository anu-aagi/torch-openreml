    "import torch\n",
    "from torch_openreml.covariance import DesignMatrix\n",
    "\n",
    "mat = DesignMatrix(torch.tensor([1.0, 2.0, 3.0, 4.0]))\n",
    "print(mat())\n",
    "\n",
    "mat = DesignMatrix([\"a\", \"b\", \"a\", \"c\"])\n",
    "print(mat())\n",
    "\n",
    "mat = DesignMatrix([\"a\", \"b\", \"a\", \"c\"], levels=[\"c\", \"b\", \"a\"])\n",
    "print(mat())"
   ]
