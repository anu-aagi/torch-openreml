   "source": [
    "import torch\n",
    "from torch_openreml.covariance import DiagonalMatrix, CovariancePropagation\n",
    "\n",
    "n, q = 6, 3\n",
    "z = torch.randn(n, q)\n",
    "g = DiagonalMatrix(q)\n",
    "op = CovariancePropagation(z=z, g=g)\n",
    "params = torch.tensor([0.0, 0.5, 1.0])\n",
    "op(params)"
   ]
  }
 ],
