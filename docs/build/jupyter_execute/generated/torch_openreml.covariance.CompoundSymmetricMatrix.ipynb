    "import torch\n",
    "from torch_openreml.covariance import CompoundSymmetricMatrix\n",
    "\n",
    "mat = CompoundSymmetricMatrix(3)\n",
    "params = torch.tensor([0.5, 0.0])\n",
    "print(mat(params))\n",
    "print(mat.grad(params))"
