    "import torch\n",
    "from torch_openreml.covariance import DiagonalMatrix\n",
    "\n",
    "mat = DiagonalMatrix(3)\n",
    "params = torch.tensor([0.0, 0.5, 1.0])\n",
    "print(mat(params))\n",
    "\n",
    "print(mat.grad(params))"
